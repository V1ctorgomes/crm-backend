generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Mude para "mysql" ou "sqlite" se for o caso do seu servidor
  url      = env("DATABASE_URL")
}

model Contact {
  number            String    @id // Ex: 558598475755
  name              String?
  profilePictureUrl String?
  lastMessage       String?
  lastMessageTime   DateTime? @default(now())
  messages          Message[]
  updatedAt         DateTime  @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  text          String   @db.Text
  type          String   // "sent" ou "received"
  timestamp     DateTime @default(now())
}