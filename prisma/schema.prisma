generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  name              String
  password          String   
  profilePictureUrl String?    
  role              String     @default("USER") // USER, ADMIN, DEVELOPER

  instances         Instance[]
  customers         Customer[]
  contacts          Contact[]
  messages          Message[]
  stages            Stage[]
  tickets           Ticket[]

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("users")
}

model Instance {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String   @unique
  status       String   @default("disconnected")
  rejectCalls  Boolean  @default(false)
  ignoreGroups Boolean  @default(false)
  proxyHost    String?
  proxyPort    String?
  proxyUser    String?
  proxyPass    String?
  proxyProto   String?  @default("http")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  number            String
  instanceName      String?
  name              String?
  profilePictureUrl String?
  lastMessage       String?   @db.Text
  lastMessageTime   DateTime?
  email             String?
  cnpj              String?
  messages          Message[]
  tickets           Ticket[]
  updatedAt         DateTime  @updatedAt

  // Permite que usuários diferentes salvem o mesmo número
  @@unique([number, userId])
}

model Message {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId     String
  contact       Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  instanceName  String?
  text          String   @db.Text
  type          String   
  isMedia       Boolean  @default(false)
  mediaData     String?  @db.Text
  mimeType      String?  
  fileName      String?
  timestamp     DateTime @default(now())
}

model Stage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#e2e8f0")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactId        String
  contact          Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  stageId          String
  stage            Stage        @relation(fields: [stageId], references: [id])
  marca            String?
  modelo           String?
  customerType     String?
  ticketType       String?      
  isArchived       Boolean      @default(false)
  resolution       String?
  resolutionReason String?      
  notes            Note[]
  tasks            Task[]       
  files            TicketFile[] 
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  title       String
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TicketFile {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  mimeType    String
  size        Int
  description String?  @db.Text
  createdAt   DateTime @default(now())
}

// Provedores e Proxies podem ser globais (sem userId) se partilhados por toda a plataforma,
// ou podem ter userId se cada cliente trouxer o seu proxy. Mantivemos globais.
model Provider {
  id        String   @id @default(uuid())
  name      String   @unique
  baseUrl   String?
  apiKey    String
  apiToken  String?
  bucket    String?
  region    String?
  accountId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proxy {
  id        String   @id @default(uuid())
  name      String
  host      String
  port      Int
  username  String?
  password  String?
  protocol  String   @default("http")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}