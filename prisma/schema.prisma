generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContactKind {
  UNKNOWN
  CUSTOMER
  INTERNAL
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String
  password          String   
  profilePictureUrl String?    
  role              String             @default("USER")
  /// Contas criadas pelo registo público ficam com false até um administrador aprovar.
  approved          Boolean            @default(true)
  instances         Instance[]
  customers         Customer[]
  contacts          Contact[]
  messages          Message[]
  stages            Stage[]
  tickets           Ticket[]
  companies         Company[]
  pushSubscriptions PushSubscription[]
  passwordResetRequests PasswordResetRequest[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("users")
}

/// Pedido de redefinição de palavra-passe (usuario indica e-mail no login; admin define nova senha).
model PasswordResetRequest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@map("password_reset_requests")
}

/// Subscrições Web Push (navegador) por usuario — usadas quando o CRM está fechado.
model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_subscriptions")
}

model Instance {
  id           String   @id @default(uuid())
  name         String   @unique
  status       String   @default("disconnected")
  rejectCalls  Boolean  @default(false)
  ignoreGroups Boolean  @default(false)
  proxyHost    String?
  proxyPort    String?
  proxyUser    String?
  proxyPass    String?
  proxyProto   String?  @default("http")
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, userId])
}

model Contact {
  id                String    @id @default(uuid())
  number            String
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceName      String?
  name              String?
  profilePictureUrl String?
  lastMessage       String?   @db.Text
  lastMessageTime   DateTime?
  email             String?
  cnpj              String?
  /// Classificação manual: cliente comercial vs colaborador no mesmo número.
  contactKind       ContactKind @default(UNKNOWN)
  messages          Message[]
  tickets           Ticket[]
  companyLinks      ContactCompany[]
  updatedAt         DateTime  @updatedAt

  @@unique([number, userId])
}

/// Empresa reutilizável dentro do utilizador: um contacto pode estar ligado a várias; uma empresa a vários contactos.
model Company {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  legalName    String
  tradeName    String?
  cnpj         String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  contactLinks ContactCompany[]
  tickets      Ticket[]

  @@unique([userId, cnpj])
  @@index([userId])
  @@index([userId, legalName])
}

model ContactCompany {
  id            String   @id @default(uuid())
  userId        String
  contactNumber String
  companyId     String
  contact       Contact  @relation(fields: [contactNumber, userId], references: [number, userId], onDelete: Cascade)
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, contactNumber, companyId])
  @@index([userId, contactNumber])
  @@index([companyId])
}

model Message {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  instanceName  String?
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber, userId], references: [number, userId], onDelete: Cascade)
  text          String   @db.Text
  type          String   
  isMedia       Boolean  @default(false)
  mediaData     String?  @db.Text
  mimeType      String?  
  fileName      String?
  /// Em grupos (@g.us), nome do membro que enviou a mensagem recebida.
  groupSenderLabel String? @db.Text
  /// text | media | sticker | reaction | location | live_location | contact | contacts | poll | poll_vote | interactive | video_note | album | unsupported
  messageKind   String?
  timestamp     DateTime @default(now())
}

model Stage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#e2e8f0")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactNumber    String
  contact          Contact      @relation(fields: [contactNumber, userId], references: [number, userId], onDelete: Cascade)
  stageId          String
  stage            Stage        @relation(fields: [stageId], references: [id])
  companyId        String?
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: Restrict)
  marca            String?
  modelo           String?
  customerType     String?
  ticketType       String?      // NOVO CAMPO: Tipo de Solicitação
  isArchived       Boolean      @default(false)
  
  resolution       String?      
  resolutionReason String?      

  notes            Note[]
  tasks            Task[]       
  files            TicketFile[] 
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  createdAt DateTime @default(now())
}

model Task {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  title       String
  dueDate     DateTime
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TicketFile {
  id          String   @id @default(uuid())
  ticketId    String
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  mimeType    String
  size        Int
  description String?  @db.Text
  createdAt   DateTime @default(now())
}

model Provider {
  id        String   @id @default(uuid())
  name      String   @unique
  baseUrl   String?
  apiKey    String
  apiToken  String?
  bucket    String?
  region    String?
  accountId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proxy {
  id        String   @id @default(uuid())
  name      String
  host      String
  port      Int
  username  String?
  password  String?
  protocol  String   @default("http")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Opções globais para OS (marca, modelo, tipo de cliente, tipo de solicitação). Apenas DEVELOPER gere.
model TicketCatalogItem {
  id        String   @id @default(uuid())
  category  String
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, label])
  @@index([category, isActive])
  @@map("ticket_catalog_items")
}

/// Auditoria de eliminações: quem, quando, motivo e snapshot JSON para suportar consulta admin e reversão futura.
model DeletionAudit {
  id           String   @id @default(uuid())
  actorUserId  String
  actorEmail   String
  actorRole    String
  resourceType String
  resourceId   String
  reason       String   @db.Text
  snapshot     Json?
  createdAt    DateTime @default(now())
  /// Preenchido quando um administrador reverteu esta exclusão (dentro da janela permitida).
  revertedAt       DateTime?
  revertedByUserId String?

  @@index([actorUserId, createdAt])
  @@index([resourceType, createdAt])
  @@index([resourceType, resourceId])
  @@map("deletion_audits")
}