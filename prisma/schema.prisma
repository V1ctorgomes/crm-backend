generator client {
  provider = "prisma-client-js"
  // Adicione esta linha de volta se ela estava no seu projeto original!
  output   = "../generated/prisma" 
}

datasource db {
  provider = "postgresql" // ou o que estava antes
  url      = env("DATABASE_URL")
}

// ==========================================
// AS SUAS TABELAS ORIGINAIS (MANTENHA-AS AQUI)
// ==========================================
model User {
  id    Int     @default(autoincrement()) @id
  // ... resto dos campos do User
}

model Customer {
  id    Int     @default(autoincrement()) @id
  // ... resto dos campos do Customer
}

// ==========================================
// AS NOSSAS NOVAS TABELAS DO WHATSAPP (COLE NO FUNDO)
// ==========================================
model Contact {
  number            String    @id
  name              String?
  profilePictureUrl String?
  lastMessage       String?
  lastMessageTime   DateTime? @default(now())
  messages          Message[]
  updatedAt         DateTime  @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  text          String   @db.Text
  type          String   
  timestamp     DateTime @default(now())
}