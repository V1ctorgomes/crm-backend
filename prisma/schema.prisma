generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  name      String
  password  String   
  role      String     @default("USER")
  instances Instance[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

model Instance {
  id           String   @id @default(uuid())
  name         String   @unique
  status       String   @default("disconnected")
  rejectCalls  Boolean  @default(false)
  ignoreGroups Boolean  @default(false)
  proxyHost    String?
  proxyPort    String?
  proxyUser    String?
  proxyPass    String?
  proxyProto   String?  @default("http")
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  number            String    @id
  instanceName      String?   
  name              String?
  profilePictureUrl String?
  lastMessage       String?   @db.Text
  lastMessageTime   DateTime?
  email             String?
  cnpj              String?
  messages          Message[]
  tickets           Ticket[]
  updatedAt         DateTime  @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  instanceName  String?  
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  text          String   @db.Text
  type          String   
  isMedia       Boolean  @default(false)
  mediaData     String?  @db.Text
  mimeType      String?  
  fileName      String?  
  timestamp     DateTime @default(now())
}

model Stage {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#e2e8f0")
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  stageId       String
  stage         Stage    @relation(fields: [stageId], references: [id])
  marca         String?
  modelo        String?
  isArchived    Boolean  @default(false)
  notes         Note[]
  files         TicketFile[] // Nova relação para os arquivos!
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  createdAt DateTime @default(now())
}

// Novo modelo para armazenar os arquivos das OS
model TicketFile {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  mimeType  String
  size      Int
  description String?  @db.Text // NOVO CAMPO DE DESCRIÇÃO
  createdAt DateTime @default(now())
}