generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AS SUAS TABELAS ORIGINAIS (COMPLETAS)
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// AS NOSSAS NOVAS TABELAS DO WHATSAPP
// ==========================================
model Contact {
  number            String    @id
  name              String?
  profilePictureUrl String?
  lastMessage       String?
  lastMessageTime   DateTime? @default(now())
  
  // ADICIONADO: E-mail e CNPJ
  email             String?
  cnpj              String?

  messages          Message[]
  updatedAt         DateTime  @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  text          String   @db.Text
  type          String   
  // NOVOS CAMPOS PARA MÍDIA:
  isMedia       Boolean  @default(false)
  mediaData     String?  @db.Text // Guardará a URL da imagem/documento
  mimeType      String?  // Ex: image/png, application/pdf
  fileName      String?  // Ex: relatorio.pdf
  timestamp     DateTime @default(now())
}