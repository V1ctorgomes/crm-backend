generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOVO: Modelo de Utilizador (Para o Login funcionar)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// O seu modelo original de Clientes
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}