generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contact {
  number            String    @id
  name              String?
  profilePictureUrl String?
  lastMessage       String?
  lastMessageTime   DateTime? @default(now())
  email             String?
  cnpj              String?

  messages          Message[]
  tickets           Ticket[]
  updatedAt         DateTime  @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  text          String   @db.Text
  type          String   
  isMedia       Boolean  @default(false)
  mediaData     String?  @db.Text
  mimeType      String?  
  fileName      String?  
  timestamp     DateTime @default(now())
}

// ==========================================
// KANBAN (SOLICITAÇÕES)
// ==========================================
model Stage {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#e2e8f0") // COR DA FASE
  order     Int      @default(0)         // SEQUÊNCIA
  isActive  Boolean  @default(true)      // ATIVA OU DESATIVADA
  tickets   Ticket[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  stageId       String
  stage         Stage    @relation(fields: [stageId], references: [id])
  
  marca         String?
  modelo        String?
  isArchived    Boolean  @default(false) // ARQUIVADO
  
  notes         Note[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Note {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  text      String   @db.Text
  createdAt DateTime @default(now())
}