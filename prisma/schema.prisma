generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOVO: Modelo de Utilizador (Para o Login funcionar)
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// O seu modelo original de Clientes
model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// AS SUAS TABELAS ORIGINAIS (MANTENHA-AS AQUI)
// ==========================================
model User {
  id    Int     @default(autoincrement()) @id
  // ... resto dos campos do User
}

model Customer {
  id    Int     @default(autoincrement()) @id
  // ... resto dos campos do Customer
}

// ==========================================
// AS NOSSAS NOVAS TABELAS DO WHATSAPP (COLE NO FUNDO)
// ==========================================
model Contact {
  number            String    @id
  name              String?
  profilePictureUrl String?
  lastMessage       String?
  lastMessageTime   DateTime? @default(now())
  messages          Message[]
  updatedAt         DateTime  @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  text          String   @db.Text
  type          String   
  timestamp     DateTime @default(now())
}