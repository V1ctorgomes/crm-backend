generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// AS SUAS TABELAS ORIGINAIS (COMPLETAS)
// ==========================================
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// AS NOSSAS NOVAS TABELAS DO WHATSAPP
// ==========================================
model Contact {
  number            String    @id
  name              String?
  profilePictureUrl String?
  lastMessage       String?
  lastMessageTime   DateTime? @default(now())
  messages          Message[]
  updatedAt         DateTime  @updatedAt
}

model Message {
  id            String   @id @default(uuid())
  contactNumber String
  contact       Contact  @relation(fields: [contactNumber], references: [number])
  text          String   @db.Text
  type          String   
  timestamp     DateTime @default(now())
}