# Copie para `.env` e preencha. Nunca commite o `.env` real.

NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/crm?schema=public

JWT_SECRET=
JWT_EXPIRES_SEC=28800

FRONTEND_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=

WEBHOOK_URL=http://localhost:3001/whatsapp/webhook
WHATSAPP_WEBHOOK_SECRET=

# Encriptação de API keys / passwords na BD (obrigatório em produção)
FIELD_ENCRYPTION_KEY=

# Opcional: Evolution (alternativa ao registo na BD Developer)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# Opcional: Cloudflare R2
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

BRASILAPI_CNPJ_BASE_URL=https://brasilapi.com.br/api/cnpj/v1
